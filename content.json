{
  "Format": "2.0.0",
  "ConfigSchema": {
    "Lake": {
      "AllowValues": "true, false",
      "Default": "true"
    },
    "WoodsShortcut": {
      "AllowValues": "true, false",
      "Default": "true"
    }
  },
  "Changes": [
    {
      "Action": "Load",
      "Target": "Maps/Farm_Foraging",
      "FromFile": "assets/maps/Farm_Ponds.tmx",
      "When": {
        "Lake": "false"
      }
    },
    {
      "Action": "Load",
      "Target": "Maps/Farm_Foraging",
      "FromFile": "assets/maps/Farm_Lake.tmx",
      "When": {
        "Lake": "true"
      }
    },
    {
      "Action": "EditMap",
      "Target": "Maps/Farm_Foraging",
      "AddWarps": ["6 59 Woods 46 4"],
      "When": {
        "WoodsShortcut": "true"
      }
    },
    {
      "Action": "EditMap",
      "Target": "Maps/Woods",
      "AddWarps": ["46 3 Farm 6 58"],
      "When": {
        "WoodsShortcut": "true"
      }
    }
  ]
}
